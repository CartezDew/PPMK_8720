# Django settings
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS – comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Path to the CSV data file (relative to BASE_DIR)
CSV_FILE_PATH=Web Dashboard Raw Data.csv

